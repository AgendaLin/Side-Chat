{
  "manifest_version": 3,
  "name": "SideChat – Side Conversations for ChatGPT & Claude",
  "version": "2.6.0",
  "description": "Select any text and open a docked side chat next to your main Claude or ChatGPT conversation",
  "permissions": [
    "clipboardWrite",
    "declarativeNetRequest",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*", "https://chatgpt.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "chatgpt_iframe_rules",
      "enabled": true,
      "path": "rules.json"
    }]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
